# Copy this file to ".env" and fill in the values from your Azure AI Foundry project.
# See docs/foundry-setup.md for where to find each value.
# NEVER commit the real .env file (it is git-ignored).

AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_API_VERSION=2024-10-21

# The deployment NAME you gave the model in Foundry (not the model id)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
